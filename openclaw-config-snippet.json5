// 盘算 Agent 配置片段
// 将以下内容合并到 ~/.openclaw/openclaw.json 中
{
  // 浏览器配置（确保启用）
  browser: {
    enabled: true,
    defaultProfile: "openclaw",
  },
  // Agent 配置
  agents: {
    pansuan: {
      // workspace 路径（按实际情况修改）
      workspace: "~/.openclaw/agents/pansuan/workspace",
      // 定时任务
      cron: [
        {
          // 赛程同步 11:10 — 仅抓取并推送今日赛程列表，不做筛选和分析
          schedule: "10 11 * * *",
          prompt: "执行赛程同步：用 match-scraper 抓取今日全量赛程，推送赛程列表给龙王。仅抓取和展示，不做筛选和分析。完成后写入今日 memory。",
        },
        {
          // 赛前分析 17:00 — 全流程分析（抓取→初筛→深度分析→精选推荐）
          schedule: "0 17 * * *",
          prompt: "先检查 memory/{今天日期}.md 中是否有 '## 跳过分析'，如果有则跳过本次执行并回复 HEARTBEAT_OK。否则执行赛前分析：1) 用 match-scraper 抓取今日赛程；2) 用 match-screening 初筛；3) 用 deep-analysis 对初筛通过的比赛做完整10步深度分析（含泊松比分建模）；4) 用 recommendation 精选2-3场并生成推荐（含串关建议）推送给龙王。每完成一步都写入今日 memory。",
        },
        {
          // 每天 09:30 执行赛后复盘
          schedule: "30 9 * * *",
          prompt: "执行赛后复盘：用 post-review 获取昨日比赛结果，对比推荐记录，计算命中率，分析失误，更新长期统计，生成复盘报告并推送给龙王。",
        },
      ],
      // 心跳间隔（默认 30 分钟）
      heartbeat: {
        every: "30m",
        // 限制在 06:00-02:00 活跃（覆盖欧洲赛事时段）
        activeHours: {
          start: "06:00",
          end: "02:00"
        },
      },
    },
  },
}